<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:http="http://www.mulesoft.org/schema/mule/http"
      xmlns:db="http://www.mulesoft.org/schema/mule/db"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core">

    <!-- Fixed: guard against empty DB results before accessing customer fields -->
    <flow name="processPaymentFlow">
        <http:listener path="/api/payments" method="POST"/>
        
        <db:select config-ref="Database_Config">
            <db:sql>SELECT * FROM customers WHERE id = :customerId</db:sql>
            <db:input-parameters>
                <![CDATA[#[{customerId: payload.customerId}]]]>
            </db:input-parameters>
        </db:select>

        <!-- Store the first customer record safely so downstream access is null-safe -->
        <set-variable variableName="customer" value="#[(payload default [])[0] default null]"/>
        
        <!-- Fix: only log/process when a matching customer record exists -->
        <choice>
            <when expression="#[vars.customer != null]">
                <!-- Safe access to customer name after null check -->
                <logger level="INFO" message="Processing payment for customer: #[vars.customer.name default 'Unknown']"/>
                
                <ee:transform>
                    <ee:message>
                        <ee:set-payload resource="dataweave/transform-payment-request.dwl"/>
                    </ee:message>
                </ee:transform>
            </when>
            <otherwise>
                <!-- Return a controlled client error instead of failing with NullPointerException -->
                <logger level="WARN" message="No customer found for provided customerId"/>
                <raise-error type="VALIDATION:INVALID_INPUT" description="Customer not found for provided customerId"/>
            </otherwise>
        </choice>
    </flow>
</mule>